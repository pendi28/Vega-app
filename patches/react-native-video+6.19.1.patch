+
+        TrackGroupArray groups = info.getTrackGroups(rendererIndex);
+        if (groups.length == 0) {
+            return false;
+        }
+
+        TrackSelection currentSelection = player.getCurrentTrackSelections().get(rendererIndex);
+        int currentGroupIndex = getSelectedGroupIndex(currentSelection, groups);
+        if (isTrackGroupSupported(info, rendererIndex, groups, currentGroupIndex)) {
+            return false;
+        }
