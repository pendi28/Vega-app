+    private boolean isPassthroughOnlyMimeType(String mimeType) {
+        if (mimeType == null || !PASSTHROUGH_AUDIO_MIME_TYPES.contains(mimeType)) {
+            return false;
+        }
+        if (FFMPEG_AUDIO_AVAILABLE) {
+            return false;
+        }
+        try {
+            java.util.List<MediaCodecInfo> decoders =
+                    MediaCodecUtil.getDecoderInfos(mimeType, false, false);
+            for (MediaCodecInfo codecInfo : decoders) {
+                if (codecInfo.softwareOnly) {
+                    return false;
+                }
+            }
+        } catch (MediaCodecUtil.DecoderQueryException ignored) {}
+        return true;
+    }
+
+    private boolean isTrackSupported(
+            MappingTrackSelector.MappedTrackInfo info,
+            int rendererIndex,
+            int groupIndex,
+            int trackIndex
+    ) {
+        int support = RendererCapabilities.getFormatSupport(
+                info.getTrackSupport(rendererIndex, groupIndex, trackIndex));
+        if (support != C.FORMAT_HANDLED && support != C.FORMAT_EXCEEDS_CAPABILITIES) {
+            return false;
+        }
+        Format format = info.getTrackGroups(rendererIndex).get(groupIndex).getFormat(trackIndex);
+        if (isPassthroughOnlyMimeType(format.sampleMimeType)) {
+            return false;
+        }
+        return true;
+    }
+
+    private boolean isTrackGroupSupported(
+            MappingTrackSelector.MappedTrackInfo info,
+            int rendererIndex,
+            TrackGroupArray groups,
+            int groupIndex
+    ) {
+        if (groupIndex == C.INDEX_UNSET || groupIndex >= groups.length) {
+            return false;
+        }
+
+        TrackGroup group = groups.get(groupIndex);
+        for (int trackIndex = 0; trackIndex < group.length; trackIndex++) {
+            if (isTrackSupported(info, rendererIndex, groupIndex, trackIndex)) {
+                return true;
+            }
+        }
+
+        return false;
+    }
+
+    private int getFirstSupportedGroupIndex(
+            MappingTrackSelector.MappedTrackInfo info,
+            int rendererIndex,
+            TrackGroupArray groups
+    ) {
+        for (int groupIndex = 0; groupIndex < groups.length; groupIndex++) {
+            if (isTrackGroupSupported(info, rendererIndex, groups, groupIndex)) {
+                return groupIndex;
+            }
+        }
+
+        return C.INDEX_UNSET;
+    }
