+        int fallbackGroupIndex = getPreferredSupportedAudioGroupIndex(
+                info,
+                rendererIndex,
+                groups,
+                audioTrackType,
+                audioTrackValue);
+
+        if (fallbackGroupIndex == C.INDEX_UNSET || fallbackGroupIndex == currentGroupIndex) {
+            return false;
+        }
+
+        long currentPosition = Math.max(player.getCurrentPosition(), 0);
+        boolean playWhenReady = player.getPlayWhenReady();
+        DebugLog.w(TAG, "Retrying playback with supported audio track group=" + fallbackGroupIndex);
+        setSelectedAudioTrack("index", String.valueOf(fallbackGroupIndex));
+        player.prepare();
+        if (currentPosition > 0) {
+            player.seekTo(currentPosition);
+        }
+        player.setPlayWhenReady(playWhenReady);
+        return true;
+    }
