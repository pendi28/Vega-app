+    private int getPreferredSupportedAudioGroupIndex(
+            MappingTrackSelector.MappedTrackInfo info,
+            int rendererIndex,
+            TrackGroupArray groups,
+            String type,
+            String value
+    ) {
+        if (groups.length == 0) {
+            return C.INDEX_UNSET;
+        }
+
+        String resolvedType = TextUtils.isEmpty(type) ? "default" : type;
+        int preferredGroupIndex = C.INDEX_UNSET;
+
+        if ("language".equals(resolvedType)) {
+            for (int groupIndex = 0; groupIndex < groups.length; groupIndex++) {
+                Format format = groups.get(groupIndex).getFormat(0);
+                if (format.language != null
+                        && format.language.equals(value)
+                        && isTrackGroupSupported(info, rendererIndex, groups, groupIndex)) {
+                    preferredGroupIndex = groupIndex;
+                    break;
+                }
+            }
+        } else if ("title".equals(resolvedType)) {
+            for (int groupIndex = 0; groupIndex < groups.length; groupIndex++) {
+                Format format = groups.get(groupIndex).getFormat(0);
+                if (format.label != null
+                        && format.label.equals(value)
+                        && isTrackGroupSupported(info, rendererIndex, groups, groupIndex)) {
+                    preferredGroupIndex = groupIndex;
+                    break;
+                }
+            }
+        } else if ("index".equals(resolvedType)) {
+            int requestedIndex = ReactBridgeUtils.safeParseInt(value, C.INDEX_UNSET);
+            if (requestedIndex != C.INDEX_UNSET
+                    && requestedIndex < groups.length
+                    && isTrackGroupSupported(info, rendererIndex, groups, requestedIndex)) {
+                preferredGroupIndex = requestedIndex;
+            }
+        } else {
+            int localeGroupIndex = getGroupIndexForDefaultLocale(groups);
+            if (isTrackGroupSupported(info, rendererIndex, groups, localeGroupIndex)) {
+                preferredGroupIndex = localeGroupIndex;
+            }
+        }
+
+        if (preferredGroupIndex != C.INDEX_UNSET) {
+            return preferredGroupIndex;
+        }
+
+        return getFirstSupportedGroupIndex(info, rendererIndex, groups);
+    }
