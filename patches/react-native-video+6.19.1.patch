+    private int getSelectedGroupIndex(TrackSelection selection, TrackGroupArray groups) {
+        if (selection == null) {
+            return C.INDEX_UNSET;
+        }
+
+        TrackGroup selectedGroup = selection.getTrackGroup();
+        for (int groupIndex = 0; groupIndex < groups.length; groupIndex++) {
+            if (groups.get(groupIndex) == selectedGroup) {
+                return groupIndex;
+            }
+        }
